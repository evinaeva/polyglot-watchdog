{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polyglot-watchdog/contract/schemas/phase4_ocr.schema.json",
  "title": "Phase 4 OCR Artifact",
  "description": "OCR output rows for approved image-backed eligible items. OCR.Space is the primary provider with optional Google Vision fallback.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "item_id",
      "page_id",
      "url",
      "language",
      "viewport_kind",
      "state",
      "user_tier",
      "source_image_uri",
      "ocr_text",
      "ocr_provider",
      "ocr_engine",
      "ocr_notes",
      "provider_meta",
      "status",
      "asset_hash",
      "src",
      "alt",
      "is_svg",
      "svg_text"
    ],
    "properties": {
      "item_id": {
        "type": "string",
        "minLength": 1
      },
      "page_id": {
        "type": [
          "string",
          "null"
        ]
      },
      "url": {
        "type": "string",
        "format": "uri"
      },
      "language": {
        "type": "string",
        "minLength": 2
      },
      "viewport_kind": {
        "type": "string"
      },
      "state": {
        "type": "string"
      },
      "user_tier": {
        "type": [
          "string",
          "null"
        ]
      },
      "source_image_uri": {
        "type": "string",
        "minLength": 1
      },
      "ocr_text": {
        "type": "string"
      },
      "ocr_provider": {
        "type": "string",
        "enum": [
          "ocr.space",
          "google_vision"
        ],
        "description": "Primary OCR provider used for this item. ocr.space is the baseline; google_vision may be used as a fallback when ocr.space is unavailable or produces unusable text."
      },
      "ocr_engine": {
        "type": "string",
        "minLength": 1,
        "description": "OCR engine identifier. For ocr.space, typically '3' (engine 3). For google_vision, a descriptive identifier such as 'google_vision_default'."
      },
      "ocr_notes": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "provider_meta": {
        "type": "object",
        "description": "Provider-specific metadata. May include fallback_attempted (boolean), attempted_providers (array of provider names), reason_for_fallback (string), and other provider-specific signals."
      },
      "status": {
        "type": "string",
        "enum": [
          "ok",
          "skipped",
          "failed"
        ],
        "description": "ok: OCR produced usable normalized text; skipped: OCR intentionally not attempted for a non-error reason; failed: OCR attempted/expected but no valid text could be produced."
      },
      "asset_hash": {
        "type": "string",
        "minLength": 1
      },
      "src": {
        "type": "string"
      },
      "alt": {
        "type": "string"
      },
      "is_svg": {
        "type": "boolean"
      },
      "svg_text": {
        "type": "string"
      }
    },
    "allOf": [
      {
        "if": {
          "properties": {
            "status": {
              "const": "ok"
            }
          }
        },
        "then": {
          "properties": {
            "ocr_text": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    ]
  }
}
