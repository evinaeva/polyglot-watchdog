{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polyglot-watchdog/contract/schemas/issues.schema.json",
  "title": "Localization Issues",
  "description": "Phase 6 QA issues artifact.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "category",
      "confidence",
      "message",
      "evidence"
    ],
    "properties": {
      "id": {
        "type": "string",
        "minLength": 1
      },
      "category": {
        "type": "string",
        "enum": ["SPELLING", "GRAMMAR", "MEANING", "PLACEHOLDER", "OCR_NOISE", "OTHER"]
      },
      "confidence": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "message": {
        "type": "string",
        "minLength": 1
      },
      "suggestion": {
        "type": ["string", "null"]
      },
      "evidence": {
        "type": "object"
      }
    }
  }
}
