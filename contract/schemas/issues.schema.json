{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polyglot-watchdog/contract/schemas/issues.schema.json",
  "title": "Localization Issues",
  "description": "Phase 6 QA issues artifact. Evidence must include at least url + bbox + screenshot storage reference.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "category",
      "confidence",
      "message",
      "evidence"
    ],
    "properties": {
      "id": {
        "type": "string",
        "minLength": 1
      },
      "category": {
        "type": "string",
        "enum": [
          "TRANSLATION_MISMATCH",
          "MISSING_TRANSLATION",
          "FORMATTING_MISMATCH",
          "LAYOUT_OVERFLOW",
          "MISSING_INTERACTIVE_STATE",
          "OVERLAY_BLOCKED_CAPTURE"
        ]
      },
      "confidence": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "message": {
        "type": "string",
        "minLength": 1
      },
      "suggestion": {
        "type": [
          "string",
          "null"
        ]
      },
      "evidence": {
        "type": "object"
      }
    }
  }
}
