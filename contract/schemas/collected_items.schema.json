{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polyglot-watchdog/contract/schemas/collected_items.schema.json",
  "title": "Collected Items",
  "description": "Phase 1 collected element/image items. Items reference page_id (page capture context), not screenshots. Per-element screenshot fields are forbidden.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "item_id",
      "page_id",
      "url",
      "language",
      "viewport_kind",
      "state",
      "user_tier",
      "element_type",
      "css_selector",
      "bbox",
      "text",
      "visible"
    ],
    "properties": {
      "item_id": {
        "type": "string",
        "minLength": 1
      },
      "page_id": {
        "type": "string",
        "minLength": 1
      },
      "url": {
        "type": "string",
        "format": "uri"
      },
      "language": {
        "type": "string",
        "minLength": 2,
        "description": "Language code or subdomain token (e.g., en, fr, el)."
      },
      "viewport_kind": {
        "type": "string",
        "enum": [
          "desktop",
          "mobile",
          "responsive"
        ]
      },
      "state": {
        "type": "string",
        "pattern": "^(guest|user|[a-z0-9]+(?:_[a-z0-9]+)*)$"
      },
      "user_tier": {
        "anyOf": [
          {
            "type": "null"
          },
          {
            "type": "string",
            "minLength": 1
          }
        ],
        "description": "Backward compatible: null allowed for legacy guest captures; string for tiered and baseline/scripted contexts."
      },
      "element_type": {
        "type": "string",
        "minLength": 1
      },
      "css_selector": {
        "type": "string",
        "minLength": 1,
        "description": "Best-effort stable selector key used for identity and rescans."
      },
      "bbox": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "x",
          "y",
          "width",
          "height"
        ],
        "properties": {
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "width": {
            "type": "number",
            "minimum": 0
          },
          "height": {
            "type": "number",
            "minimum": 0
          }
        }
      },
      "text": {
        "type": "string"
      },
      "visible": {
        "type": "boolean"
      },
      "tag": {
        "type": [
          "string",
          "null"
        ]
      },
      "attributes": {
        "type": [
          "object",
          "null"
        ]
      }
    },
    "allOf": [
      {
        "not": {
          "required": [
            "screenshotId"
          ]
        }
      },
      {
        "not": {
          "required": [
            "element_screenshot"
          ]
        }
      },
      {
        "not": {
          "required": [
            "elementScreenshot"
          ]
        }
      },
      {
        "not": {
          "required": [
            "screenshot_id"
          ]
        }
      }
    ]
  }
}
