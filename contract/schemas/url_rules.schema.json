{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polyglot-watchdog/contract/schemas/url_rules.schema.json",
  "title": "URL Rules",
  "description": "UI-managed URL filtering rules for Phase 0/1 crawling and pulling. Used to drop pagination URLs for specific path patterns without global query stripping.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "rules"
  ],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rule_id",
          "enabled",
          "description",
          "match",
          "action"
        ],
        "properties": {
          "rule_id": {
            "type": "string",
            "minLength": 1
          },
          "enabled": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          },
          "match": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path_prefix",
              "query_param"
            ],
            "properties": {
              "path_prefix": {
                "type": "string",
                "minLength": 1
              },
              "query_param": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "action": {
            "type": "string",
            "enum": [
              "DROP_URL"
            ]
          }
        }
      }
    }
  }
}