{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polyglot-watchdog/contract/schemas/eligible_dataset.schema.json",
  "title": "Eligible Dataset",
  "description": "Phase 3 eligible dataset derived deterministically from collected_items + template_rules (and/or re-pull mode).",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "item_id",
      "url",
      "language",
      "text"
    ],
    "properties": {
      "item_id": {
        "type": "string",
        "minLength": 1
      },
      "page_id": {
        "type": [
          "string",
          "null"
        ]
      },
      "url": {
        "type": "string",
        "format": "uri"
      },
      "language": {
        "type": "string",
        "minLength": 2
      },
      "element_type": {
        "type": [
          "string",
          "null"
        ]
      },
      "text": {
        "type": "string"
      },
      "mask_applied": {
        "type": "boolean"
      },
      "page_canonical_key": {
        "type": [
          "string",
          "null"
        ]
      },
      "logical_match_key": {
        "type": [
          "string",
          "null"
        ]
      },
      "role_hint": {
        "type": [
          "string",
          "null"
        ]
      },
      "semantic_attrs": {
        "type": [
          "object",
          "null"
        ]
      },
      "local_path_signature": {
        "type": [
          "string",
          "null"
        ]
      },
      "container_signature": {
        "type": [
          "string",
          "null"
        ]
      },
      "stable_ordinal": {
        "type": [
          "integer",
          "null"
        ],
        "minimum": 0
      }
    }
  }
}
