{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polyglot-watchdog/contract/schemas/seed_urls.schema.json",
  "title": "Seed URLs",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "domain",
    "urls"
  ],
  "properties": {
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "urls": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          },
          "recipe_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "default": []
          }
        }
      }
    }
  }
}
